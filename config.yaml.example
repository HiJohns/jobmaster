# JobMaster 本地开发配置示例
# 复制此文件为 config.yaml 并根据需要修改

# 服务器配置
server:
  port: 5555         # PC 端口 (PC 前端 + API)
  port_mobile: 5558   # Mobile 端口 (Mobile 前端 + API)
  mode: debug

# 数据库配置
database:
  host: localhost
  port: 5432
  user: jobmaster
  password: jobmaster_dev_password
  dbname: jobmaster
  sslmode: disable

# 日志级别: silent, error, warn, info
db_log_level: info

# JWT 配置
jwt:
  secret: "your-jwt-secret-key-change-in-production"
  expiration: 86400

# Redis 配置 (可选)
redis:
  host: localhost
  port: 6379
  password: ""
  db: 0

# IAM 配置
iam:
  base_url: "https://iam.beacon.cn"          # Beacon-IAM 服务地址
  client_id: "jobmaster"                      # JobMaster 在 IAM 注册的身份
  client_secret: ""                           # 密钥（生产环境通过环境变量注入）
  public_key: ""                              # 用于本地离线校验 JWT 签名的公钥（RS256）
  callback_url: "/api/v1/auth/callback"       # OIDC 回调路径
