# JobMaster 本地开发配置示例
# 复制此文件为 config.yaml 并根据需要修改

# 服务器配置
server:
  port: 8080
  mode: debug

# 数据库配置
database:
  host: localhost
  port: 5432
  user: jobmaster
  password: jobmaster_dev_password
  dbname: jobmaster
  sslmode: disable

# 日志级别: silent, error, warn, info
db_log_level: info

# JWT 配置
jwt:
  secret: "your-jwt-secret-key-change-in-production"
  expiration: 86400

# Redis 配置 (可选)
redis:
  host: localhost
  port: 6379
  password: ""
  db: 0
